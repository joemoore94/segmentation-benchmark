# Data (downloaded/derived - too large for git)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Results that can be regenerated
results/figures/*
results/tables/*
!results/figures/.gitkeep
!results/tables/.gitkeep
# ...except figure PNGs, which the README links to and should render on GitHub
!results/figures/*.png
!results/figures/umap/
!results/figures/umap/*.png
!results/figures/lum_ep_subtypes/
!results/figures/lum_ep_subtypes/*.png

# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/

# Environments
.venv/
env/

# Julia
Manifest.toml

# OS
.DS_Store
